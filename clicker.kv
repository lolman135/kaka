#:kivy 2.1.0
#:import from_hex kivy.utils.get_color_from_hex
#:import colormap kivy.utils.colormap

#:set main_color "#F3AF12"
#:set main_color_dark "#F37C12"

<ButtonMenu@Button>:
    font_size: "20sp"
    size_hint: 1, 0.5
    background_normal: ''
    background_color: from_hex(main_color)
    color: (0, 0, 0, 1)
    on_press: 
        self.background_color = from_hex(main_color_dark)
    on_release:
        self.background_color = from_hex(main_color)

<Menu>:
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        canvas.before:
            Color: 
                rgba: colormap['blue']
            Rectangle: 
                pos: self.pos
                size: self.size

        Label:
            text: "Main Menu"
            font_size: "40sp"
            size_hint: 1, 0.2

        ButtonMenu:
            text: 'PLAY'
            on_press: root.go_game()

        ButtonMenu:
            text: 'SETTINGS'
            on_press: root.go_settings()

        ButtonMenu:
            text: 'EXIT'
            on_press: root.exit_app()

<Settings>:
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        canvas.before:
            Color: 
                rgba: colormap['blue']
            Rectangle: 
                pos: self.pos
                size: self.size

        Label:
            text: "Settings"
            font_size: "40sp"
            size_hint: 1, 0.2

        ButtonMenu:
            text: 'GO BACK'
            on_press: root.go_menu()

<Game>:
    BoxLayout:
        orientation: "vertical"
        padding: "20dp"
        spacing: "20dp"

        canvas.before:
            Color: 
                rgba: colormap['blue']
            Rectangle: 
                pos: self.pos
                size: self.size

        Label:
            text: "Game"
            font_size: "40sp"
            size_hint: 1, 0.2

        Label:
            id: level_complete
            text: "LEVEL COMPLETE!"
            font_size: "40sp"
            opacity: 0

        RelativeLayout:
            Fish:
                id: fish

        Label:
            id: click_label
            text: f"Clicks: {root.score}"
            font_size: "30sp"

        ButtonMenu:
            text: 'GO BACK'
            on_press: root.go_menu()

<Fish>:
    size_hint: None, None
    size: 300, 300
    pos_hint: {'center_x': 0.5}